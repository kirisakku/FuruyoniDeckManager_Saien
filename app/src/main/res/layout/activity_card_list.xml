<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CardListActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginVertical="8dp"
            android:text="カード一覧を確認したいメガミを選択してください"
            android:textSize="16sp" />
        <TableLayout
            android:layout_width="wrap_content"
            android:layout_height="420dp"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp">

                <ImageButton
                    android:id="@+id/yurina"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:contentDescription="@string/yurina"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/yurina"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/himika"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/himika"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/himika"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/tokoyo"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/tokoyo"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/tokoyo"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/oboro"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/oboro"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/oboro"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/yukihi"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/yukihi"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/yukihi"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />
            </TableRow>

            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="10dp">

                <ImageButton
                    android:id="@+id/shinra"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/shinra"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/shinra"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/saine"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/saine"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/saine"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/hagane"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/hagane"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/hagane"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/chikage"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/chikage"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/chikage"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/kururu"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/kururu"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/kururu"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />
            </TableRow>

            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="10dp">

                <ImageButton
                    android:id="@+id/sariya"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/sariya"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/sariya"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/raira"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/raira"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/raira"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="10dp" />

                <ImageButton
                    android:id="@+id/korunu"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/korunu"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/korunu"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="10dp" />

                <ImageButton
                    android:id="@+id/megumi"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0000"
                    android:contentDescription="@string/megumi"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/megumi"
                    tools:layout_editor_absoluteX="16dp"
                    tools:layout_editor_absoluteY="16dp" />
            </TableRow>
        </TableLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>